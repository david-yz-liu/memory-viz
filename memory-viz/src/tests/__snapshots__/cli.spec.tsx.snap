          });

          idText.addEventListener('mouseout', () = & gt;
          {
            const objectIds = idToObjectMap[idValue];
            if (objectIds) {
              objectIds.forEach(removeHighlight);
            }
          });
        });
      }

      addEventListeners();
    }

    // Wait for DOM to be ready
    if (document.readyState === 'loading') {
