        objectBox.classList.remove('highlighted');
      }

      function addEventListeners() {
        document.querySelectorAll('text.id').forEach(idText = & gt;
        {
          const idValue = idText.textContent.trim();
          if (!idValue || !idValue.startsWith('id')) {
