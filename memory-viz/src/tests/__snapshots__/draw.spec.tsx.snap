exports[`draw function renders a diagram with large left margins 1`] = `
<svg width="615.2" height="714" xmlns="http://www.w3.org/2000/svg">
  <title>Python memory model diagram showing stack frames and objects</title>
  <style>
    :root {
      --fade-text-color: rgb(0, 0, 0);
