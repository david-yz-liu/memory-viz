      text-anchor: middle;
    }

    text.value {
      fill: rgb(27, 14, 139);
      text-anchor: middle;
    }

    path {
      stroke: rgb(0, 0, 0);
    }

    .highlighted path {
      fill: var(--highlight-object-fill) !important;
