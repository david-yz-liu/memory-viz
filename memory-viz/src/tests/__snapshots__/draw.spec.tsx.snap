      --default-font-size: 20px;

      --highlight-object-fill: rgba(255, 255, 0, 0.6);
    }

    text {
      font-family: Consolas, Courier;
      font-size: 20px;
    }

    text.default {
      fill: rgb(0, 0, 0);
      text-anchor: middle;
    }

    text.attribute {
      fill: rgb(27, 14, 139);
