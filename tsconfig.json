{
    "compilerOptions": {
        "allowJs": true,
        "allowSyntheticDefaultImports": true,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "lib": ["ES2022", "DOM"],
        "module": "es2020",
        "moduleResolution": "bundler",
        "skipLibCheck": true,
        "sourceMap": true,
        "strict": true,
        "target": "es2020",
        "types": ["node", "@types/jest"]
    },
    "include": ["memory-viz/src/**/*"]
}
